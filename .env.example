# Copy this to .env and fill in real values
DATABASE_URL=postgresql+asyncpg://infovac:infovac_dev@localhost:5432/infovac
SYNC_DATABASE_URL=postgresql://infovac:infovac_dev@localhost:5432/infovac

# Required for Instructor smoke test and Phase 1+ extraction
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional — only needed in Phase 2+ for discovery
TAVILY_API_KEY=tvly-YOUR_KEY_HERE
FIRECRAWL_API_KEY=fc-YOUR_KEY_HERE

# Optional — LangSmith tracing for LangGraph/pipeline debugging
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__YOUR_KEY_HERE
LANGCHAIN_PROJECT=infovac

